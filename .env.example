# ─────────────────────────────────────────────────────────────────────────
# Fusion Cell — environment variables
#
# Copy this file to `.env.local` (Next.js auto-loads it in dev) and fill in
# real values. For Vercel / production, set the same keys in the project
# settings — Vercel will surface them at runtime.
#
# NEXT_PUBLIC_* values are EXPOSED to the browser bundle. Anything secret
# (service role key, API keys for third-party services) must NOT carry that
# prefix.
# ─────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────
# Project URL — visible to the browser (used by the JS client + middleware).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anonymous key — visible to the browser, RLS is the security boundary.
# Get from: Supabase dashboard → Project Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Service role key — server-only. Bypasses RLS. Used by /api/admin/* routes
# for auth.admin.* operations (creating users, sending invites, etc.).
# Never reference this in any file imported by the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=ey...

# ─── Anthropic (Advanced Search) ─────────────────────────────────────────
# Server-only. Used by /api/ai/chat and /api/search.
# If not set, Advanced Search returns a clean "not configured" error.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Mapbox (Globe + map views) ──────────────────────────────────────────
# Public token, OK to expose. Get from: account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.ey...
